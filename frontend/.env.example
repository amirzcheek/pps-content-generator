# Адрес backend-ядра. Скопируйте в .env и при необходимости измените.
#
# Пусто  -> запросы идут на /api (через прокси Vite в dev или reverse-proxy на проде).
# Либо укажите полный адрес ядра, например: http://127.0.0.1:8080
VITE_API_BASE=

# Базовый URL портала (бренд, «Выйти», «Админка» в навбаре ведут туда).
# По умолчанию: https://ai.knus.edu.kz
VITE_PORTAL_URL=

# Превью админ-вида при локальной разработке (показывает ссылку «Админка»),
# пока SSO/сессия портала не подключены. На проде роль берётся из /api/auth/session.
# Значение true включает показ.
VITE_PREVIEW_ADMIN=
