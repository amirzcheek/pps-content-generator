# Пример переменных окружения сервиса генератора учебного контента.
# Скопируйте в .env и подставьте реальные значения:  cp .env.example .env

# === LLM для русского и английского (локальная модель 14b, OpenAI-совместимый API) ===
# Адрес OpenAI-совместимого эндпоинта модели.
# ВНИМАНИЕ: при запуске в Docker, если LLM на том же хосте, используйте
# host.docker.internal вместо 127.0.0.1 (и раскомментируйте extra_hosts в compose).
LLM_BASE_URL=http://127.0.0.1:11434/v1
# Имя модели, как оно зарегистрировано в вашем OpenAI-совместимом сервере.
LLM_MODEL=qwen3-14b
# Ключ. Для локальных моделей обычно не требуется — оставьте заглушку.
LLM_API_KEY=not-needed

# === Казахский (KazLLM / Sherkala) — ПОКА НЕДОСТУПНО ===
# Первая версия работает только на русском/английском (модель 14b).
# Оставьте пустыми; заполните, когда появится казахская модель.
KAZ_BASE_URL=
KAZ_MODEL=
KAZ_API_KEY=

# === Адрес публикации порта сервиса ===
# 127.0.0.1               — если nginx на ТОМ ЖЕ хосте, что и сервис.
# Внутренний IP web-сервера — если nginx на ОТДЕЛЬНОМ сервере (тогда обязательно
#                            ограничьте 8080 фаерволом только для nginx-хоста).
BIND_IP=127.0.0.1
# То же значение для systemd-варианта (uvicorn --host ${BIND_HOST}):
BIND_HOST=127.0.0.1

# === CORS ===
# Сервис стоит за nginx и тестовая страница same-origin, поэтому CORS обычно НЕ нужен.
# Заполните, только если фронтенд будет ходить с другого домена (через запятую).
# CORS_ORIGINS=https://content.ai.knus.edu.kz
