# Пример переменных окружения сервиса генератора учебного контента.
# Скопируйте в .env и подставьте реальные значения:  cp .env.example .env

# === ОСНОВНАЯ (локальная) модель — ru / en, OpenAI-совместимый API ===
# Используется в первую очередь. Если недоступна — автоматический переход на
# резервную (Gemini, см. FALLBACK_* ниже).
# ВНИМАНИЕ: при запуске в Docker, если эндпоинт на том же хосте, используйте
# host.docker.internal вместо 127.0.0.1 (и раскомментируйте extra_hosts в compose).
# Локальная модель ещё не готова -> оставьте LLM_* пустыми: всё пойдёт на Gemini.
LLM_BASE_URL=
# Имя локальной модели (как зарегистрировано в вашем сервере). Передаётся ЯВНО.
LLM_MODEL=
LLM_API_KEY=not-needed

# === Казахский (необязательно) ===
# Отдельный эндпоинт/модель для kk. Если пусто — kk идёт на LLM_*, а при их
# отсутствии — на резервную Gemini.
KAZ_BASE_URL=
KAZ_MODEL=
KAZ_API_KEY=

# === РЕЗЕРВНАЯ (облачная) модель — Gemini ===
# Включается, когда локальная недоступна, и для ресёрч-запросов (prefer_fallback).
# Имя модели указывается ЯВНО и дешёвое — иначе шлюз берёт дорогую по умолчанию.
FALLBACK_BASE_URL=
FALLBACK_MODEL=gemini-3.1-flash-lite
FALLBACK_API_KEY=

# === Под-путь на портале ===
# Префикс, под которым агент проксируется на ai.knus.edu.kz/agents/<slug>.
# Нужен FastAPI для корректных URL в Swagger за reverse-proxy.
# Должен совпадать с VITE_BASE/VITE_API_BASE сборки фронтенда и с location в nginx.
ROOT_PATH=/agents/course-dev-content-generator

# === Адрес публикации порта сервиса ===
# 127.0.0.1               — если nginx на ТОМ ЖЕ хосте, что и сервис.
# Внутренний IP web-сервера — если nginx на ОТДЕЛЬНОМ сервере (тогда обязательно
#                            ограничьте 8080 фаерволом только для nginx-хоста).
BIND_IP=127.0.0.1
# То же значение для systemd-варианта (uvicorn --host ${BIND_HOST}):
BIND_HOST=127.0.0.1

# === CORS ===
# Сервис стоит за nginx и тестовая страница same-origin, поэтому CORS обычно НЕ нужен.
# Заполните, только если фронтенд будет ходить с другого домена (через запятую).
# CORS_ORIGINS=https://content.ai.knus.edu.kz
